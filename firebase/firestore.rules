rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // The single platform admin is identified by users/{uid}.role == 'admin'.
    // This flag can ONLY be set via the Admin SDK (set-admin script), never by
    // the client, because the rules below forbid self-promotion.
    function isAdmin() {
      return request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'business') == 'admin';
    }

    function isBusinessAdmin(businessId) {
      let biz = get(/databases/$(database)/documents/businesses/$(businessId)).data;
      return request.auth != null && (
        biz.ownerId == request.auth.uid ||
        request.auth.uid in biz.get('adminIds', [])
      );
    }

    match /users/{uid} {
      allow read: if request.auth != null && (request.auth.uid == uid || isAdmin());

      // A self-registering business may only create their own profile as a
      // 'business'. They can never create themselves as 'admin'.
      allow create: if request.auth.uid == uid &&
        request.resource.data.get('role', 'business') == 'business';

      // Users may update their own profile but cannot change their role
      // (only the Admin SDK can elevate someone to 'admin').
      allow update: if request.auth.uid == uid &&
        request.resource.data.get('role', 'business') == resource.data.get('role', 'business');

      allow update, read: if isAdmin();
    }

    match /businesses/{businessId} {
      allow read: if request.auth != null && (
        resource.data.ownerId == request.auth.uid ||
        request.auth.uid in resource.data.get('adminIds', []) ||
        isAdmin()
      );

      allow create: if request.auth != null &&
        request.resource.data.ownerId == request.auth.uid &&
        request.auth.uid in request.resource.data.get('adminIds', []);

      allow update, delete: if request.auth != null && (
        resource.data.ownerId == request.auth.uid ||
        request.auth.uid in resource.data.get('adminIds', []) ||
        isAdmin()
      );

      match /{subcollection}/{docId} {
        allow read, write: if isBusinessAdmin(businessId) || isAdmin();
      }
    }

    match /conversations/{convId} {
      allow read: if request.auth != null;
      allow write: if false;

      match /messages/{messageId} {
        allow read: if request.auth != null;
        allow write: if false;
      }
    }

    match /appointments/{apptId} {
      allow read, write: if request.auth != null;
    }

    match /leads/{leadId} {
      allow read, write: if request.auth != null;
    }

    match /analytics/{businessId} {
      allow read: if request.auth != null;
      allow write: if false;

      match /daily/{date} {
        allow read: if request.auth != null;
        allow write: if false;
      }
    }

    match /broadcasts/{broadcastId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    match /errors/{errorId} {
      allow read, write: if false;
    }

    match /usage/{businessId} {
      allow read: if request.auth != null;
      allow write: if false;

      match /monthly/{month} {
        allow read: if request.auth != null;
        allow write: if false;
      }
    }

    match /payments/{paymentId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    match /notifications/{notifId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Platform billing & plan catalog — backend Admin SDK only
    match /platform/{docId} {
      allow read, write: if false;
    }
  }
}
