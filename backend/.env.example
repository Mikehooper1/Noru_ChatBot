# ── Server ────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# Public URL of THIS backend (used for widget + in-chat checkout links)
# e.g.  //your-backend.up.railway.app  (no trailing slash)
BACKEND_URL=https://noruchatbot-production.up.railway.app

# Admin dashboard URL (for upgrade links shown in chat)
ADMIN_DASHBOARD_URL=https://norutech.com/

# ── Firebase Admin SDK ────────────────────────────────────
# Option A (local .env): three separate vars — private_key must use \n for line breaks
FIREBASE_PROJECT_ID=noruchatbot
