# ── Server ────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# Public URL of THIS backend (used for widget + in-chat checkout links)
# e.g. https://your-backend.up.railway.app  (no trailing slash)
BACKEND_URL=http://localhost:3000

# Admin dashboard URL (for upgrade links shown in chat)
ADMIN_DASHBOARD_URL=http://localhost:5173

# ── Firebase Admin SDK ────────────────────────────────────
# Option A (local .env): three separate vars — private_key must use \n for line breaks
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com

# Option B (Railway — recommended): paste the FULL service account JSON as one line
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n",...}

# Option C: path to downloaded JSON file
# GOOGLE_APPLICATION_CREDENTIALS=./serviceAccount.json

# ── Gemini AI (the ONLY AI provider) ──────────────────────
# Add as many keys as you want. When one hits its rate/quota limit,
# the agent automatically rotates to the next key, then the next model.
#
# Option A (recommended): comma-separated list
GEMINI_API_KEYS=AIzaKey1,AIzaKey2,AIzaKey3
# Option B: single key
GEMINI_API_KEY=
# Option C: numbered keys (GEMINI_API_KEY_2 ... GEMINI_API_KEY_10)
GEMINI_API_KEY_2=
GEMINI_API_KEY_3=

# Default + fallback model (must start with "gemini")
GEMINI_MODEL=gemini-2.5-flash
GEMINI_FALLBACK_MODEL=gemini-2.5-flash

# ── Encryption (for storing channel tokens in Firestore) ──
ENCRYPTION_KEY=32-char-random-string-here!!!!!!

# ── WhatsApp (Meta Cloud API) ─────────────────────────────
WHATSAPP_VERIFY_TOKEN=your_random_verify_token

# ── Razorpay (UPI + Card payments) ────────────────────────
# Leave blank to run payments in MOCK mode for local testing.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# Optional separate secret for signed in-chat checkout tokens
CHECKOUT_SECRET=

# ── Google Calendar (optional) ────────────────────────────
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=
GOOGLE_CALENDAR_REDIRECT_URI=

# ── Email (SMTP) — used for lead follow-ups to website leads ──
# Leave blank to disable email follow-ups (WhatsApp/Telegram still work).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
# From address shown on outgoing emails (defaults to SMTP_USER)
SMTP_FROM=

# ── Twilio (Phone Voice AI channel) ───────────────────────
# Platform credentials — businesses map their Twilio number in Admin → Channels → Phone Voice
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# ── Seed script — set to your Firebase Auth UID ───────────
SEED_OWNER_ID=your-firebase-auth-uid
