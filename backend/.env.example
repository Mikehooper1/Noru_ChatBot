# Server
PORT=3000
NODE_ENV=development

# Firebase Admin SDK
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com

# AI Providers (automatic failover when rate limits are hit)
# Comma-separate multiple keys per provider for extra capacity
OPENAI_API_KEY=your-openai-api-key
OPENAI_API_KEYS=
OPENAI_FALLBACK_MODEL=gpt-4o-mini

GEMINI_API_KEY=your-gemini-api-key
GEMINI_API_KEYS=
GEMINI_FALLBACK_MODEL=gemini-2.0-flash

# Provider failover order (tries next on rate limit / quota errors)
AI_PROVIDER_ORDER=openai,gemini

# WhatsApp (Meta Cloud API)
WHATSAPP_VERIFY_TOKEN=your_random_verify_token
WHATSAPP_APP_SECRET=your_meta_app_secret

# Google Calendar
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=
GOOGLE_CALENDAR_REDIRECT_URI=

# Encryption (for storing API tokens in Firestore)
ENCRYPTION_KEY=32-char-random-string-here!!

# Seed script — set to your Firebase Auth UID
SEED_OWNER_ID=your-firebase-auth-uid

# Razorpay (UPI + Card payments) — https://dashboard.razorpay.com
RAZORPAY_KEY_ID=rzp_test_xxxx
RAZORPAY_KEY_SECRET=your-razorpay-secret

# Admin dashboard URL (for upgrade links in chat)
ADMIN_DASHBOARD_URL=https://noruchatbotadmin.netlify.app

# Public backend URL (for WhatsApp/Telegram inline checkout links)
BACKEND_URL=https://your-backend.up.railway.app

# Optional: separate secret for signed checkout tokens (defaults to RAZORPAY_KEY_SECRET)
CHECKOUT_SECRET=
